{
  "name": "media-transcriber",
  "version": "1.0.0",
  "description": "Batch transcribe audio/video files using pluggable AI backends (Whisper, OpenAI API, and more)",
  "type": "module",
  "bin": {
    "media-transcriber": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "transcription",
    "whisper",
    "audio",
    "video",
    "speech-to-text",
    "srt",
    "subtitle",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "commander": "^13.0.0",
    "cosmiconfig": "^9.0.0",
    "execa": "^9.0.0",
    "ora": "^8.0.0",
    "picocolors": "^1.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
